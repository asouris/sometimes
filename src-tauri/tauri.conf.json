{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "sometimes",
  "version": "0.1.0",
  "identifier": "sometimes",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
    {
        "visible": false,
        "title": "sometimes",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "externalBin": ["bin/api/main"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
            "../backend/data.json" : "resources/data.json"
        }
  }
}
